# Optional: production site URL for canonical links and social previews (Vercel sets VERCEL_URL if unset)
# NEXT_PUBLIC_SITE_URL=https://www.accountantscompanion.com

# OpenAI API Key (required)
OPENAI_API_KEY=sk-...

# Web3Forms Access Key for rating notifications (free - get yours at https://web3forms.com)
# 1. Go to https://web3forms.com
# 2. Enter your email to receive ratings
# 3. Copy the access key and paste below
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
